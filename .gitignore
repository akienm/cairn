# class-space holds code only — no state, ever (CLAUDE.md).
# Instance-space lives at ~/.cairn/, a separate root, never here.

# Python build/run cruft — artifacts of running the code, not the code (state)
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
venv/

# OS / editor cruft
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/
